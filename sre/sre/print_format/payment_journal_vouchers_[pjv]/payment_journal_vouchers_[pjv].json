 "doctype": "Print Format",
 "font_size": 14,
 "html": "<div class=\"container\" style=\"font-family: Arial, Helvetica, sans-serif; max-width: 800px; margin: 0 auto; font-size: 11pt;\">\n    <!-- Header -->\n    <div style=\"text-align: center; margin-bottom: 20px;\">\n        <h3 style=\"margin: 0; font-size: 16pt; text-transform: uppercase;\">\n            {{ doc.company }}\n        </h3>\n        <h3 style=\"margin: 5px 0; font-size: 13pt;\">\n            {% if doc.payment_type == \"Receive\" %}\n                RECEIPT JOURNAL VOUCHER [RJV]\n            {% elif doc.payment_type == \"Pay\" %}\n                PAYMENT JOURNAL VOUCHER [PJV]\n            {% else %}\n                INTERNAL TRANSFER VOUCHER [ITV]\n            {% endif %}\n        </h3>\n    </div>\n\n    <!-- Date, Voucher No, Mode of Payment -->\n    <div style=\"display: flex; justify-content: space-between; margin-bottom: 10px; border-bottom: 1px solid #000; padding-bottom: 8px;\">\n        <div>\n            <strong>Date: {{ frappe.format_date(doc.posting_date, \"dd-MM-yyyy\") }}</strong>\n        </div>\n        <div>\n            <strong>Mode: {{ doc.mode_of_payment or \"\" }}</strong>\n        </div>\n        <div>\n            <strong>Voucher No: {{ doc.name }}</strong>\n        </div>\n    </div>\n\n    <!-- Payment Info Row -->\n    <div style=\"display: flex; justify-content: space-between; margin-bottom: 10px; padding-bottom: 6px; border-bottom: 1px solid #ddd;\">\n        <div>\n            <strong>Payment Type:</strong> {{ doc.payment_type }}\n        </div>\n        <div>\n            <strong>Party Type:</strong> {{ doc.party_type or \"\" }}\n        </div>\n        <div>\n            <strong>Party:</strong> {{ doc.party_name or doc.party or \"\" }}\n        </div>\n    </div>\n\n    <!-- Reference / Cheque Details -->\n    {% if doc.reference_no or doc.reference_date %}\n    <div style=\"display: flex; justify-content: space-between; margin-bottom: 10px; padding-bottom: 6px; border-bottom: 1px solid #ddd;\">\n        <div>\n            <strong>Reference / Cheque No:</strong> {{ doc.reference_no or \"\" }}\n        </div>\n        <div>\n            <strong>Reference / Cheque Date:</strong> \n            {% if doc.reference_date %}\n                {{ frappe.format_date(doc.reference_date, \"dd-MM-yyyy\") }}\n            {% endif %}\n        </div>\n    </div>\n    {% endif %}\n\n    <!-- Rupees Header -->\n    <div style=\"display: flex; justify-content: space-between; margin-bottom: 6px;\">\n        <div></div>\n        <div style=\"border-bottom: 1px solid #000; min-width: 120px; text-align: center; padding-bottom: 2px;\">\n            <strong>Rupees</strong>\n        </div>\n    </div>\n\n    <!-- Main Accounting Table -->\n    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 15px; font-size: 10.5pt;\">\n        <thead>\n            <tr>\n                <th style=\"text-align: left; padding: 6px 4px; border-bottom: 2px solid #000; font-weight: bold;\">Account Title</th>\n                <th style=\"text-align: left; padding: 6px 4px; border-bottom: 2px solid #000; font-weight: bold;\">Account No.</th>\n                <th style=\"text-align: left; padding: 6px 4px; border-bottom: 2px solid #000; font-weight: bold;\">Remarks</th>\n                <th style=\"text-align: center; padding: 6px 4px; border-bottom: 2px solid #000; font-weight: bold;\">Cost Center</th>\n                <th style=\"text-align: center; padding: 6px 4px; border-bottom: 2px solid #000; font-weight: bold;\">Ref #</th>\n                <th style=\"text-align: right; padding: 6px 4px; border-bottom: 2px solid #000; font-weight: bold;\">Debit</th>\n                <th style=\"text-align: right; padding: 6px 4px; border-bottom: 2px solid #000; font-weight: bold;\">Credit</th>\n            </tr>\n        </thead>\n        <tbody>\n            <!-- ========== PAID FROM ACCOUNT (Source) ========== -->\n            {% set paid_from_acc = frappe.get_doc(\"Account\", doc.paid_from) if doc.paid_from else None %}\n            <tr style=\"border-bottom: 1px solid #ddd;\">\n                <td style=\"padding: 6px 4px;\">\n                    {{ paid_from_acc.account_name if paid_from_acc else (doc.paid_from or \"\") }}\n                </td>\n                <td style=\"padding: 6px 4px;\">\n                    {{ paid_from_acc.account_number if paid_from_acc and paid_from_acc.account_number else \"\" }}\n                </td>\n                <td style=\"padding: 6px 4px;\">\n                    {{ doc.remarks or \"\" }}\n                </td>\n                <td style=\"text-align: center; padding: 6px 4px;\">\n                    {{ doc.cost_center or \"\" }}\n                </td>\n                <td style=\"text-align: center; padding: 6px 4px;\">\n                    {{ doc.reference_no or \"\" }}\n                </td>\n                <!-- Paid From is CREDITED for Pay, DEBITED for Receive -->\n                {% if doc.payment_type == \"Pay\" or doc.payment_type == \"Internal Transfer\" %}\n                <td style=\"text-align: right; padding: 6px 4px;\"></td>\n                <td style=\"text-align: right; padding: 6px 4px;\">\n                    {{ \"{:,.2f}\".format(doc.paid_amount or 0) }}\n                </td>\n                {% elif doc.payment_type == \"Receive\" %}\n                <td style=\"text-align: right; padding: 6px 4px;\">\n                    {{ \"{:,.2f}\".format(doc.paid_amount or 0) }}\n                </td>\n                <td style=\"text-align: right; padding: 6px 4px;\"></td>\n                {% endif %}\n            </tr>\n\n            <!-- ========== PAID TO ACCOUNT (Target) ========== -->\n            {% set paid_to_acc = frappe.get_doc(\"Account\", doc.paid_to) if doc.paid_to else None %}\n            <tr style=\"border-bottom: 1px solid #ddd;\">\n                <td style=\"padding: 6px 4px;\">\n                    {{ paid_to_acc.account_name if paid_to_acc else (doc.paid_to or \"\") }}\n                </td>\n                <td style=\"padding: 6px 4px;\">\n                    {{ paid_to_acc.account_number if paid_to_acc and paid_to_acc.account_number else \"\" }}\n                </td>\n                <td style=\"padding: 6px 4px;\">\n                    {{ doc.remarks or \"\" }}\n                </td>\n                <td style=\"text-align: center; padding: 6px 4px;\">\n                    {{ doc.cost_center or \"\" }}\n                </td>\n                <td style=\"text-align: center; padding: 6px 4px;\">\n                    {{ doc.reference_no or \"\" }}\n                </td>\n                <!-- Paid To is DEBITED for Pay, CREDITED for Receive -->\n                {% if doc.payment_type == \"Pay\" or doc.payment_type == \"Internal Transfer\" %}\n                <td style=\"text-align: right; padding: 6px 4px;\">\n                    {{ \"{:,.2f}\".format(doc.received_amount or 0) }}\n                </td>\n                <td style=\"text-align: right; padding: 6px 4px;\"></td>\n                {% elif doc.payment_type == \"Receive\" %}\n                <td style=\"text-align: right; padding: 6px 4px;\"></td>\n                <td style=\"text-align: right; padding: 6px 4px;\">\n                    {{ \"{:,.2f}\".format(doc.received_amount or 0) }}\n                </td>\n                {% endif %}\n            </tr>\n\n            <!-- ========== DEDUCTIONS (Taxes/Charges) ========== -->\n            {% if doc.deductions %}\n            {% for row in doc.deductions %}\n            {% set ded_acc = frappe.get_doc(\"Account\", row.account) if row.account else None %}\n            <tr style=\"border-bottom: 1px solid #ddd;\">\n                <td style=\"padding: 6px 4px;\">\n                    {{ ded_acc.account_name if ded_acc else (row.account or \"\") }}\n                </td>\n                <td style=\"padding: 6px 4px;\">\n                    {{ ded_acc.account_number if ded_acc and ded_acc.account_number else \"\" }}\n                </td>\n                <td style=\"padding: 6px 4px;\">\n                    {{ row.description or \"\" }}\n                </td>\n                <td style=\"text-align: center; padding: 6px 4px;\">\n                    {{ row.cost_center or \"\" }}\n                </td>\n                <td style=\"text-align: center; padding: 6px 4px;\"></td>\n                <td style=\"text-align: right; padding: 6px 4px;\">\n                    {% if (row.amount or 0) > 0 %}\n                        {{ \"{:,.2f}\".format(row.amount or 0) }}\n                    {% endif %}\n                </td>\n                <td style=\"text-align: right; padding: 6px 4px;\">\n                    {% if (row.amount or 0) < 0 %}\n                        {{ \"{:,.2f}\".format((row.amount or 0) * -1) }}\n                    {% endif %}\n                </td>\n            </tr>\n            {% endfor %}\n            {% endif %}\n\n            <!-- ========== TAXES (if applicable) ========== -->\n            {% if doc.taxes %}\n            {% for tax in doc.taxes %}\n            {% set tax_acc = frappe.get_doc(\"Account\", tax.account_head) if tax.account_head else None %}\n            <tr style=\"border-bottom: 1px solid #ddd;\">\n                <td style=\"padding: 6px 4px;\">\n                    {{ tax_acc.account_name if tax_acc else (tax.account_head or \"\") }}\n                </td>\n                <td style=\"padding: 6px 4px;\">\n                    {{ tax_acc.account_number if tax_acc and tax_acc.account_number else \"\" }}\n                </td>\n                <td style=\"padding: 6px 4px;\">\n                    {{ tax.description or \"\" }}\n                </td>\n                <td style=\"text-align: center; padding: 6px 4px;\">\n                    {{ tax.cost_center or \"\" }}\n                </td>\n                <td style=\"text-align: center; padding: 6px 4px;\"></td>\n                <td style=\"text-align: right; padding: 6px 4px;\">\n                    {% if (tax.tax_amount or 0) > 0 %}\n                        {{ \"{:,.2f}\".format(tax.tax_amount or 0) }}\n                    {% endif %}\n                </td>\n                <td style=\"text-align: right; padding: 6px 4px;\">\n                    {% if (tax.tax_amount or 0) < 0 %}\n                        {{ \"{:,.2f}\".format((tax.tax_amount or 0) * -1) }}\n                    {% endif %}\n                </td>\n            </tr>\n            {% endfor %}\n            {% endif %}\n        </tbody>\n\n        <!-- ========== TOTALS ========== -->\n        <tfoot>\n            {% set total_debit = [] %}\n            {% set total_credit = [] %}\n\n            <!-- Calculate totals based on payment type -->\n            {% if doc.payment_type == \"Pay\" or doc.payment_type == \"Internal Transfer\" %}\n                {% set _ = total_credit.append(doc.paid_amount or 0) %}\n                {% set _ = total_debit.append(doc.received_amount or 0) %}\n            {% elif doc.payment_type == \"Receive\" %}\n                {% set _ = total_debit.append(doc.paid_amount or 0) %}\n                {% set _ = total_credit.append(doc.received_amount or 0) %}\n            {% endif %}\n\n            <!-- Add deductions -->\n            {% if doc.deductions %}\n            {% for row in doc.deductions %}\n                {% if (row.amount or 0) > 0 %}\n                    {% set _ = total_debit.append(row.amount or 0) %}\n                {% elif (row.amount or 0) < 0 %}\n                    {% set _ = total_credit.append((row.amount or 0) * -1) %}\n                {% endif %}\n            {% endfor %}\n            {% endif %}\n\n            <!-- Add taxes -->\n            {% if doc.taxes %}\n            {% for tax in doc.taxes %}\n                {% if (tax.tax_amount or 0) > 0 %}\n                    {% set _ = total_debit.append(tax.tax_amount or 0) %}\n                {% elif (tax.tax_amount or 0) < 0 %}\n                    {% set _ = total_credit.append((tax.tax_amount or 0) * -1) %}\n                {% endif %}\n            {% endfor %}\n            {% endif %}\n\n            <tr style=\"font-weight: bold;\">\n                <td colspan=\"5\" style=\"padding: 8px 4px; text-align: right; border-top: 2px solid #000;\">\n                    <strong>TOTAL</strong>\n                </td>\n                <td style=\"text-align: right; padding: 8px 4px; border-top: 2px solid #000;\">\n                    <strong>{{ \"{:,.2f}\".format(total_debit | sum) }}</strong>\n                </td>\n                <td style=\"text-align: right; padding: 8px 4px; border-top: 2px solid #000;\">\n                    <strong>{{ \"{:,.2f}\".format(total_credit | sum) }}</strong>\n                </td>\n            </tr>\n        </tfoot>\n    </table>\n\n    <!-- Against References Table -->\n    {% if doc.references %}\n    <div style=\"margin-bottom: 15px;\">\n        <h4 style=\"margin: 0 0 8px 0; font-size: 11pt; border-bottom: 1px solid #000; padding-bottom: 4px;\">\n            Payment References\n        </h4>\n        <table style=\"width: 100%; border-collapse: collapse; font-size: 10pt;\">\n            <thead>\n                <tr>\n                    <th style=\"text-align: left; padding: 4px; border-bottom: 1px solid #000;\">Type</th>\n                    <th style=\"text-align: left; padding: 4px; border-bottom: 1px solid #000;\">Name</th>\n                    <th style=\"text-align: right; padding: 4px; border-bottom: 1px solid #000;\">Grand Total</th>\n                    <th style=\"text-align: right; padding: 4px; border-bottom: 1px solid #000;\">Outstanding</th>\n                    <th style=\"text-align: right; padding: 4px; border-bottom: 1px solid #000;\">Allocated</th>\n                </tr>\n            </thead>\n            <tbody>\n                {% for ref in doc.references %}\n                <tr style=\"border-bottom: 1px solid #ddd;\">\n                    <td style=\"padding: 4px;\">{{ ref.reference_doctype or \"\" }}</td>\n                    <td style=\"padding: 4px;\">{{ ref.reference_name or \"\" }}</td>\n                    <td style=\"text-align: right; padding: 4px;\">\n                        {{ \"{:,.2f}\".format(ref.total_amount or 0) }}\n                    </td>\n                    <td style=\"text-align: right; padding: 4px;\">\n                        {{ \"{:,.2f}\".format(ref.outstanding_amount or 0) }}\n                    </td>\n                    <td style=\"text-align: right; padding: 4px;\">\n                        {{ \"{:,.2f}\".format(ref.allocated_amount or 0) }}\n                    </td>\n                </tr>\n                {% endfor %}\n            </tbody>\n        </table>\n    </div>\n    {% endif %}\n\n    <!-- Amount in Words + Remarks -->\n    <div style=\"margin: 20px 0 25px 0;\">\n        <div style=\"font-style: italic; font-weight: bold; text-align: left;\">\n            Rupees {{ frappe.utils.money_in_words(doc.paid_amount or 0, doc.paid_from_account_currency or \"PKR\") }}\n        </div>\n\n        <hr style=\"border: none; border-top: 1px solid #000; margin: 8px 0 10px 0; width: 100%;\">\n\n        {% if doc.remarks %}\n        <div style=\"font-weight: bold; font-size: 11pt; text-align: left;\">\n            {{ doc.remarks }}\n        </div>\n        {% endif %}\n    </div>\n\n    <!-- Signatures -->\n    <div style=\"display: flex; justify-content: space-between; margin-top: 60px; font-size: 10pt;\">\n        <div style=\"text-align: center; width: 18%;\">\n            <div style=\"border-top: 1px solid #000; margin-top: 40px;\"><strong>Prepared By</strong></div>\n        </div>\n        <div style=\"text-align: center; width: 18%;\">\n            <div style=\"border-top: 1px solid #000; margin-top: 40px;\"><strong>Verified By</strong></div>\n        </div>\n        <div style=\"text-align: center; width: 18%;\">\n            <div style=\"border-top: 1px solid #000; margin-top: 40px;\"><strong>Approved By</strong></div>\n        </div>\n        <div style=\"text-align: center; width: 18%;\">\n            <div style=\"border-top: 1px solid #000; margin-top: 40px;\"><strong>Received By</strong></div>\n        </div>\n        <div style=\"text-align: center; width: 18%;\">\n            <div style=\"border-top: 1px solid #000; margin-top: 40px;\"><strong>Audited By</strong></div>\n        </div>\n    </div>\n</div>\n\n<style>\n    @media print {\n        .container { width: 100% !important; margin: 0; padding: 10mm; }\n        table { page-break-inside: auto; }\n        tr { page-break-inside: avoid; page-break-after: auto; }\n    }\n</style>",
